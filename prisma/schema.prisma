generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique
  username              String    @unique
  firstName             String
  lastName              String
  password              String?
  provider              String    @default("email")
  membershipStatus      String    @default("free")
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?
  subscriptionPlan      String?
  subscriptionEndsAt    DateTime?
  isBlocked             Boolean   @default(false)
  blockReason           String?
  lastTradeAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  walletAddress         String?
  walletNetwork         String?
  referredByAffiliateId Int?
  registrationIpHash    String?

  trades           Trade[]
  positions        Position[]
  balanceLogs      BalanceLog[]
  challenges       Challenge[]
  subscriptions    Subscription[]
  payoutRequests   PayoutRequest[]
  auditLogsAsActor AuditLog[]      @relation("AuditActor")
  userConsent      UserConsent?
  payments         Payment[]

  @@index([isBlocked])
  @@index([stripeCustomerId])
}

model UserConsent {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  acceptedPayoutRules Boolean  @default(false)
  acceptedPrivacy     Boolean  @default(false)
  acceptedAt          DateTime
  ipAddress           String?

  user User @relation(fields: [userId], references: [id])
}

model Market {
  id                 String    @id
  conditionId        String    @unique
  slug               String
  title              String
  description        String?
  category           String    @default("other")
  imageUrl           String?
  yesPrice           Float
  noPrice            Float
  volume24h          Float     @default(0)
  endDate            DateTime
  status             String    @default("live")
  winningOutcome     String?
  negRisk            Boolean   @default(false)
  isRestricted       Boolean   @default(false)
  resolutionSource   String?
  resolvedExternalAt DateTime?
  lastSyncedAt       DateTime
  createdAt          DateTime  @default(now())

  trades    Trade[]
  positions Position[]

  @@index([status])
  @@index([status, negRisk])
  @@index([endDate])
}

model Trade {
  id                        Int      @id @default(autoincrement())
  userId                    Int
  marketId                  String
  challengeId               Int?
  side                      String
  action                    String
  amount                    Int
  price                     Float
  cost                      Float
  marketYesPriceAtExecution Float
  marketNoPriceAtExecution  Float
  createdAt                 DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  market      Market       @relation(fields: [marketId], references: [id])
  challenge   Challenge?   @relation(fields: [challengeId], references: [id])
  balanceLogs BalanceLog[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([marketId, action])
  @@index([challengeId])
  @@index([userId, marketId])
}

model Position {
  id          Int       @id @default(autoincrement())
  userId      Int
  marketId    String
  challengeId Int?
  side        String
  status      String    @default("open")
  shares      Int       @default(0)
  avgPrice    Float     @default(0)
  costBasis   Float     @default(0)
  realizedPnl Float     @default(0)
  version     Int       @default(0)
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  resolvedAt  DateTime?

  user      User       @relation(fields: [userId], references: [id])
  market    Market     @relation(fields: [marketId], references: [id])
  challenge Challenge? @relation(fields: [challengeId], references: [id])

  @@index([userId, status])
  @@index([marketId, status])
  @@index([challengeId])
}

model BalanceLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  tradeId        Int?
  challengeId    Int?
  type           String
  amount         Float
  balanceBefore  Float
  balanceAfter   Float
  runningBalance Float
  createdAt      DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  trade     Trade?     @relation(fields: [tradeId], references: [id])
  challenge Challenge? @relation(fields: [challengeId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([tradeId])
  @@index([challengeId, createdAt(sort: Desc)])
}

model ChallengePlan {
  id                  Int         @id @default(autoincrement())
  name                String
  price               Float
  accountSize         Float
  profitTargetPct     Float
  maxLossPct          Float
  dailyLossPct        Float
  maxPositionSizePct  Float
  minTradingDays      Int
  payoutCap           Float?
  priceCents          Int         @default(0)
  refundableFeeCents  Int         @default(0)
  maxPayoutCapCents   Int         @default(0)
  minPayoutCents      Int         @default(5000)
  profitSharePct      Float       @default(80)
  challengePeriodDays Int         @default(30)
  payoutCooldownDays  Int         @default(14)
  isActive            Boolean     @default(true)
  isPopular           Boolean     @default(false)
  order               Int         @default(0)
  createdAt           DateTime    @default(now())
  challenges          Challenge[]
  payments            Payment[]
}

model Challenge {
  id                   Int       @id @default(autoincrement())
  userId               Int
  planId               Int?
  stage                String
  status               String    @default("active")
  startBalance         Float     @default(10000)
  realizedBalance      Float
  peakBalance          Float
  profitTargetPct      Float
  maxDailyDdPct        Float
  maxTotalDdPct        Float
  maxPositionSizePct   Float     @default(5)
  minTradingDays       Int
  tradingDaysCount     Int       @default(0)
  profitTargetMet      Boolean   @default(false)
  drawdownViolated     Boolean   @default(false)
  dayStartBalance      Float?
  dayStartDate         DateTime?
  lastTradingDay       DateTime?
  violationReason      String?
  expiresAt            DateTime?
  payoutCapCents       Int?
  minPayoutCents       Int?
  profitSharePct       Float?
  refundableFeeCents   Int?
  payoutCooldownDays   Int?
  refundableFeePaidAt  DateTime?
  lastApprovedPayoutAt DateTime?
  startedAt            DateTime  @default(now())
  endedAt              DateTime?

  user           User            @relation(fields: [userId], references: [id])
  plan           ChallengePlan?  @relation(fields: [planId], references: [id])
  trades         Trade[]
  positions      Position[]
  balanceLogs    BalanceLog[]
  payoutRequests PayoutRequest[]

  @@index([userId, status])
  @@index([status])
}

model Subscription {
  id                   Int       @id @default(autoincrement())
  userId               Int
  stripeSubscriptionId String    @unique
  stripeCustomerId     String
  plan                 String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([stripeCustomerId])
}

model ProcessedStripeEvent {
  eventId     String   @id
  processedAt DateTime @default(now())
}

model PayoutRequest {
  id                      Int       @id @default(autoincrement())
  userId                  Int
  challengeId             Int
  amount                  Float
  maxPayoutAmount         Float
  feePct                  Float     @default(20)
  platformFee             Float
  netAmount               Float
  status                  String    @default("pending")
  rejectionReason         String?
  requestedAt             DateTime  @default(now())
  processedAt             DateTime?
  paidAt                  DateTime?
  walletAddress           String?
  walletNetwork           String?
  txHash                  String?
  currency                String    @default("USDT")
  baseAmountCents         Int?
  refundableFeeBonusCents Int?
  finalAmountCents        Int?

  user      User      @relation(fields: [userId], references: [id])
  challenge Challenge @relation(fields: [challengeId], references: [id])

  @@index([userId, status])
  @@index([challengeId, status])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  targetType String
  targetId   String
  category   String
  action     String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([targetType, targetId])
  @@index([actorId])
  @@index([createdAt(sort: Desc)])
  @@index([category])
}

model ContentBlock {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model FAQItem {
  id        Int      @id @default(autoincrement())
  category  String
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  avatar    String   @default("")
  text      String
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id           Int      @id @default(autoincrement())
  userId       Int
  planId       Int?
  nowPaymentId String?  @unique
  orderId      String   @unique
  amount       Float
  currency     String   @default("USD")
  payCurrency  String?
  payAmount    Float?
  status       String   @default("pending")
  paymentUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User           @relation(fields: [userId], references: [id])
  plan ChallengePlan? @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([orderId])
}

model LeaderboardEntry {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  plan      String
  totalPnl  Float
  winRate   Int
  trades    Int
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([totalPnl])
}

// ─────────────────────────────────────────────────────────────
// AFFILIATE PROGRAM — Phase 1 MVP
// Added 2026-05-01. Do not modify existing models above.
// ─────────────────────────────────────────────────────────────

enum AffiliateStatus {
  pending
  approved
  suspended
  rejected
  banned
}

enum AffiliateConversionStatus {
  pending
  pending_review
  approved
  paid
  rejected
  clawback
  frozen
}

enum AffiliatePayoutStatus {
  requested
  approved
  processing
  completed
  failed
  cancelled
}

enum AffiliateLedgerBucket {
  pending
  available
  frozen
  negative
}

enum AffiliateLedgerType {
  commission_pending
  commission_approved
  commission_rejected
  commission_frozen
  commission_unfrozen
  payout_paid
  clawback
  negative_offset
  adjustment_credit
  adjustment_debit
}

enum KycStatus {
  not_required
  required
  submitted
  verified
  rejected
}

enum AffiliatePaymentMethod {
  usdt_trc20
  usdc_polygon
  usdt_erc20
  usdc_erc20
}

enum AffiliateRejectionReason {
  refund
  chargeback
  inactivity
  fraud
  manual
  manual_fraud
  wallet_collision
  referred_user_banned
}

model Affiliate {
  id                      Int                     @id @default(autoincrement())
  userId                  Int                     @unique
  refCode                 String                  @unique
  status                  AffiliateStatus         @default(pending)
  tier                    String                  @default("starter")
  applicationData         Json
  approvedAt              DateTime?
  rejectedAt              DateTime?
  suspendedAt             DateTime?
  bannedAt                DateTime?
  approvedBy              String?
  rejectionReason         String?
  isVerified              Boolean                 @default(false)
  suspiciousFlag          Boolean                 @default(false)
  suspiciousReason        String?
  paymentMethod           AffiliatePaymentMethod?
  paymentWallet           String?
  paymentWalletVerifiedAt DateTime?
  walletChangedAt         DateTime?
  walletLockUntil         DateTime?
  walletRequiresReview    Boolean                 @default(false)
  kycStatus               KycStatus               @default(not_required)
  kycVerifiedAt           DateTime?
  kycCountry              String?
  kycAdminNote            String?
  balancePending          Float                   @default(0)
  balanceAvailable        Float                   @default(0)
  balanceFrozen           Float                   @default(0)
  balanceNegative         Float                   @default(0)
  lifetimeEarned          Float                   @default(0)
  lifetimePaid            Float                   @default(0)
  lifetimeClawedBack      Float                   @default(0)
  salesCount30d           Int                     @default(0)
  parentAffiliateId       Int?
  customCommissionRate    Float?
  notificationsEnabled    Boolean                 @default(false)
  acceptedTermsVersion    String                  @default("1.0")
  acceptedTermsAt         DateTime
  programVersion          String                  @default("1.0")
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  parent      Affiliate?            @relation("AffiliateParent", fields: [parentAffiliateId], references: [id], onDelete: SetNull)
  children    Affiliate[]           @relation("AffiliateParent")
  clicks      AffiliateClick[]
  conversions AffiliateConversion[]
  ledger      AffiliateLedger[]
  payouts     AffiliatePayout[]

  @@index([status])
  @@index([tier])
  @@index([suspiciousFlag])
  @@index([createdAt])
}

model AffiliateClick {
  id                Int      @id @default(autoincrement())
  affiliateId       Int
  refCode           String
  ipHash            String
  ipSalt            String?
  countryCode       String?
  userAgent         String?
  referer           String?
  landingUrl        String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  cookieId          String
  convertedToUserId Int?
  createdAt         DateTime @default(now())
  expiresAt         DateTime

  affiliate   Affiliate             @relation(fields: [affiliateId], references: [id], onDelete: Restrict)
  conversions AffiliateConversion[]

  @@index([expiresAt])
  @@index([cookieId])
  @@index([convertedToUserId, createdAt])
  @@index([affiliateId, createdAt])
}

model AffiliateConversion {
  id                         Int                        @id @default(autoincrement())
  affiliateId                Int
  referredUserId             Int
  paymentId                  Int                        @unique
  planId                     Int
  clickId                    Int?
  grossAmount                Float
  discountAmount             Float                      @default(0)
  processorFeeAmount         Float                      @default(0)
  netAmount                  Float
  commissionRate             Float
  commissionAmount           Float
  status                     AffiliateConversionStatus  @default(pending)
  previousStatus             AffiliateConversionStatus?
  pendingUntil               DateTime
  paymentStatusAtCreation    String
  paymentStatusLastChecked   String?
  paymentStatusLastCheckedAt DateTime?
  approvedAt                 DateTime?
  rejectedAt                 DateTime?
  rejectionReason            AffiliateRejectionReason?
  reviewedBy                 String?
  reviewNote                 String?
  reviewRequiredAt           DateTime?
  paidAt                     DateTime?
  payoutId                   Int?
  activityCheckedAt          DateTime?
  referralActivityDays       Int                        @default(0)
  referralTradesCount        Int                        @default(0)
  frozenFromBucket           AffiliateLedgerBucket?
  lastStatusChangeAt         DateTime
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  affiliate     Affiliate         @relation(fields: [affiliateId], references: [id], onDelete: Restrict)
  click         AffiliateClick?   @relation(fields: [clickId], references: [id], onDelete: SetNull)
  payout        AffiliatePayout?  @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  ledgerEntries AffiliateLedger[]

  @@index([affiliateId, status])
  @@index([referredUserId])
  @@index([status, pendingUntil])
  @@index([reviewRequiredAt])
  @@index([payoutId])
}

model AffiliateLedger {
  id               Int                   @id @default(autoincrement())
  affiliateId      Int
  conversionId     Int?
  payoutId         Int?
  type             AffiliateLedgerType
  bucket           AffiliateLedgerBucket
  amount           Float
  balanceAfter     Float
  operationGroupId String
  reason           String?
  createdByAdmin   String?
  createdAt        DateTime              @default(now())

  affiliate  Affiliate            @relation(fields: [affiliateId], references: [id], onDelete: Restrict)
  conversion AffiliateConversion? @relation(fields: [conversionId], references: [id], onDelete: Restrict)
  payout     AffiliatePayout?     @relation(fields: [payoutId], references: [id], onDelete: Restrict)

  @@index([affiliateId, bucket])
  @@index([operationGroupId])
  @@index([createdAt])
  @@index([conversionId])
  @@index([payoutId])
}

model AffiliatePayout {
  id                    Int                    @id @default(autoincrement())
  affiliateId           Int
  status                AffiliatePayoutStatus  @default(requested)
  amount                Float
  networkFee            Float                  @default(0)
  amountAfterFee        Float
  paymentMethod         AffiliatePaymentMethod
  paymentWallet         String
  network               String
  includedConversionIds Json
  transactionHash       String?                @unique
  nowpaymentsBatchId    String?
  requestedAt           DateTime
  approvedAt            DateTime?
  approvedBy            String?
  processedAt           DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  cancelledAt           DateTime?
  failureReason         String?
  adminNote             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  affiliate     Affiliate             @relation(fields: [affiliateId], references: [id], onDelete: Restrict)
  conversions   AffiliateConversion[]
  ledgerEntries AffiliateLedger[]

  @@index([affiliateId, status])
  @@index([status])
  @@index([requestedAt])
}
